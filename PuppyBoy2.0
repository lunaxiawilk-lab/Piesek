
-- Wait for player to load 
local PlayerService = game:GetService("Players") 
local RunService = game:GetService("RunService") 
local player = PlayerService.LocalPlayer 
if not player then player = PlayerService.PlayerAdded:Wait() end 

-- Wait for player GUI to be ready 
player:WaitForChild("PlayerGui") 

-- Create ScreenGui 
local screenGui = Instance.new("ScreenGui") 
screenGui.ResetOnSpawn = false 
screenGui.Name = "GuiVersion24_Titled" 

-- PRIORYTETOWE WYŚWIETLANIE (Wymuszenie najwyższej warstwy i ominięcie marginesów)
screenGui.DisplayOrder = 999999999 
screenGui.IgnoreGuiInset = true    

-- SYSTEM WYBORU NAJBEZPIECZNIEJSZEJ WARSTWY (CoreGui -> PlayerGui)
local success, coreGui = pcall(function() return game:GetService("CoreGui") end)
if success and coreGui then
    screenGui.Parent = coreGui
else
    screenGui.Parent = player.PlayerGui
end

-- Create Main Drag Frame (The window container)
local mainContainer = Instance.new("Frame") 
mainContainer.Parent = screenGui 
mainContainer.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Czarna główna ramka
mainContainer.Size = UDim2.new(0, 200, 0, 100) 
mainContainer.Position = UDim2.new(0.3, 0, 0.5, -50) 
mainContainer.Active = true 
mainContainer.Draggable = true 
mainContainer.BorderSizePixel = 2 

-- NOWY ELEMENT: Tytuł GUI na samej górze (Złoty napis, czarne tło)
local titleLabel = Instance.new("TextLabel")
titleLabel.Parent = mainContainer
titleLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Czarne tło tytułu
titleLabel.Size = UDim2.new(0, 200, 0, 25)
titleLabel.Position = UDim2.new(0, 0, 0, -55) -- Umieszczony nad statusem
titleLabel.Text = "Puppy Boy Gui"
titleLabel.TextColor3 = Color3.fromRGB(255, 215, 0) -- Złoty kolor napisu
titleLabel.TextScaled = true
titleLabel.BorderSizePixel = 1 -- Delikatne obramowanie, żeby pasowało do reszty

-- Status Label (Przesunięty delikatnie w dół pod tytuł)
local statusLabel = Instance.new("TextLabel") 
statusLabel.Parent = mainContainer 
statusLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Czarna ramka statusu
statusLabel.Size = UDim2.new(0, 200, 0, 25) 
statusLabel.Position = UDim2.new(0, 0, 0, -30) -- Pod tytułem, nad menu głównym
statusLabel.Text = "Status: Offline" 
statusLabel.TextColor3 = Color3.fromRGB(255, 100, 0) -- Neonowy pomarańczowy
statusLabel.TextScaled = true 

-- Create Scrolling List for MAIN BUTTONS (Przewijanie menu głównego)
local mainScroll = Instance.new("ScrollingFrame") 
mainScroll.Parent = mainContainer 
mainScroll.Size = UDim2.new(1, -10, 1, -10) 
mainScroll.Position = UDim2.new(0, 5, 0, 5) 
mainScroll.BackgroundTransparency = 1 
mainScroll.ScrollBarThickness = 4 
mainScroll.CanvasSize = UDim2.new(0, 0, 0, 160) 

local mainListLayout = Instance.new("UIListLayout") 
mainListLayout.Parent = mainScroll 
mainListLayout.Padding = UDim.new(0, 5) 

-- Create Small Toggle Square (Mały kwadracik do przywracania GUI)
local toggleSquare = Instance.new("TextButton") 
toggleSquare.Parent = screenGui 
toggleSquare.BackgroundColor3 = Color3

