
-- Bring Player GUI - Wersja 2026 (Naprawiona i Zoptymalizowana)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local lp = Players.LocalPlayer

-- Tworzenie GUI w Twoim stylu (Czerń i Złoto)
local screenGui = Instance.new("ScreenGui", CoreGui)
screenGui.Name = "BringPlayerGUI"

local main = Instance.new("Frame", screenGui)
main.Size = UDim2.new(0, 220, 0, 160)
main.Position = UDim2.new(0.5, -110, 0.5, -80)
main.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
main.BorderSizePixel = 2
main.BorderColor3 = Color3.fromRGB(255, 215, 0)
main.Active = true
main.Draggable = true

local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 30)
title.Text = "BRING PLAYER"
title.TextColor3 = Color3.fromRGB(255, 215, 0)
title.Font = Enum.Font.SourceSansBold
title.TextSize = 18
title.BackgroundTransparency = 1

local textBox = Instance.new("TextBox", main)
textBox.Size = UDim2.new(0.9, 0, 0, 40)
textBox.Position = UDim2.new(0.05, 0, 0.3, 0)
textBox.PlaceholderText = "Wpisz nick..."
textBox.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
textBox.BorderSizePixel = 1
textBox.BorderColor3 = Color3.fromRGB(255, 215, 0)

local bringBtn = Instance.new("TextButton", main)
bringBtn.Size = UDim2.new(0.9, 0, 0, 40)
bringBtn.Position = UDim2.new(0.05, 0, 0.65, 0)
bringBtn.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
bringBtn.Text = "ZASSAJ GRACZA"
bringBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
bringBtn.Font = Enum.Font.SourceSansBold

-- Logika Bring
local function getPlayer(name)
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name:lower() then return p end
    end
    return nil
end

bringBtn.MouseButton1Click:Connect(function()
    local target = getPlayer(textBox.Text)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local myHRP = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        local targetHRP = target.Character.HumanoidRootPart
        
        if myHRP then
            -- Naprawa: Wymuszamy fizykę, która przyciąga gracza
            target.Character.Humanoid.PlatformStand = true
            
            local connection
            connection = RunService.RenderStepped:Connect(function()
                if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    targetHRP.AssemblyLinearVelocity = (myHRP.Position - targetHRP.Position) * 10
                else
                    connection:Disconnect()
                end
            end)
            
            task.wait(1.5) -- Czas przyciągania
            connection:Disconnect()
            target.Character.Humanoid.PlatformStand = false
        end
    end
end)

