-- Funkcja przyciągania
local function bringPlayer(targetName)
    local target = nil
    for _, p in pairs(PlayerService:GetPlayers()) do
        if p.Name:lower():sub(1, #targetName) == targetName:lower() then
            target = p
            break
        end
    end

    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local myChar = player.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            local myHRP = myChar.HumanoidRootPart
            local targetHRP = target.Character.HumanoidRootPart
            local originalPos = myHRP.CFrame

            -- Proces Bring
            myChar.Humanoid.PlatformStand = true
            for i = 1, 10 do
                myHRP.CFrame = targetHRP.CFrame
                myHRP.Velocity = Vector3.new(9999, 9999, 9999)
                task.wait(0.05)
            end
            myHRP.CFrame = originalPos
            myChar.Humanoid.PlatformStand = false
        end
    end
end

bringButton.MouseButton1Click:Connect(function()
    bringPlayer(nameTextBox.Text)
end)

