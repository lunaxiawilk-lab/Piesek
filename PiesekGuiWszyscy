
-- SERWER-SIDE PUPPY MASTER (Wersja Finalna: Strict Target)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- UI
local screenGui = Instance.new("ScreenGui", game:GetService("CoreGui") or LocalPlayer:FindFirstChild("PlayerGui"))
local main = Instance.new("Frame", screenGui)
main.Size = UDim2.new(0, 200, 0, 180); main.Position = UDim2.new(0.5, -100, 0.5, -90)
main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); main.Active = true; main.Draggable = true

local nameBox = Instance.new("TextBox", main)
nameBox.Size = UDim2.new(1, -10, 0, 30); nameBox.Position = UDim2.new(0, 5, 0, 5)
nameBox.PlaceholderText = "Wpisz nick ofiary..."; nameBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)

local onBtn = Instance.new("TextButton", main)
onBtn.Size = UDim2.new(1, -10, 0, 30); onBtn.Position = UDim2.new(0, 5, 0, 40)
onBtn.Text = "ON (Przejmij)"; onBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)

local status = Instance.new("TextLabel", main)
status.Size = UDim2.new(1, -10, 0, 30); status.Position = UDim2.new(0, 5, 0, 75)
status.Text = "Status: Oczekiwanie"; status.BackgroundTransparency = 1

-- Zmienne celu
local targetPlayer = nil
local activeAnims = {}

-- IDs - tutaj Twoje 4 główne animacje
local ANIMS = {
    Run = "rbxassetid://108985707207747",
    Walk = "rbxassetid://84792004932424",
    Idle1 = "rbxassetid://120467296669059",
    Idle2 = "rbxassetid://73644021399239"
}

-- Znajdowanie gracza
local function getTarget(name)
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name:lower() then return p end
    end
    return nil
end

-- GŁÓWNA LOGIKA PRZEJMOWANIA (Server-Side)
local function takeover(player)
    local char = player.Character
    if not char then return end
    
    -- 1. Usuwamy oryginalny system animacji (KLUCZOWE)
    local animate = char:FindFirstChild("Animate")
    if animate then animate:Destroy() end
    
    -- 2. Tworzymy nowy Animator
    local hum = char:FindFirstChild("Humanoid")
    local animator = hum:FindFirstChild("Animator") or Instance.new("Animator", hum)
    
    -- 3. Ładujemy nasze animacje
    for name, id in pairs(ANIMS) do
        local a = Instance.new("Animation")
        a.AnimationId = id
        activeAnims[name] = animator:LoadAnimation(a)
    end
    
    -- 4. Uruchamiamy pętlę zachowania (idle)
    status.Text = "Przejęto: " .. player.Name
    activeAnims.Idle1:Play()
end

-- PRZYCISK ON
onBtn.MouseButton1Click:Connect(function()
    local found = getTarget(nameBox.Text)
    if found then
        targetPlayer = found
        takeover(targetPlayer)
    else
        status.Text = "Nie znaleziono gracza!"
    end
end)

