-- LOGIKA PRZEJĘCIA ANIMACJI
local targetPlayer = nil

local function getTrueId(id) return "rbxassetid://" .. tostring(id) end

local function applyAnimations(char)
    local hum = char:WaitForChild("Humanoid")
    local animate = char:FindFirstChild("Animate")
    
    -- Jeśli skrypt animacji istnieje, podmieniamy w nim wartości StringValue
    if animate then
        -- Tablica z Twoimi animacjami pieska
        local anims = {
            run = getTrueId("108985707207747"),
            walk = getTrueId("84792004932424"),
            idle = getTrueId("120467296669059") -- Główne Idle spoczynkowe
        }
        
        -- Nadpisujemy ID wewnątrz folderów domyślnego skryptu Roblox
        for animName, id in pairs(anims) do
            local folder = animate:FindFirstChild(animName)
            if folder then
                -- Szukamy obiektów typu Animation wewnątrz folderu (np. WalkAnim, RunAnim)
                for _, child in pairs(folder:GetChildren()) do
                    if child:IsA("Animation") then
                        child.AnimationId = id
                    end
                end
            end
        end
        
        -- WYMUSZENIE ODŚWIEŻENIA STANU (Żeby gra natychmiast załadowała nowe ID)
        -- Przemieszczamy na chwilę postać lub zmieniamy jej stan, by zresetować skrypt Animate
        hum:ChangeState(Enum.HumanoidStateType.Landed)
        task.wait(0.1)
        hum:ChangeState(Enum.HumanoidStateType.Running)
    end
end

local function findTarget(name)
    if name == "" or name == " " then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name:lower() then return p end
    end
    return nil
end

onBtn.MouseButton1Click:Connect(function()
    local p = findTarget(nameInput.Text)
    if p and p.Character then
        targetPlayer = p
        applyAnimations(p.Character)
        print("Pomyślnie podmieniono animacje spoczynku i ruchu u: " .. p.Name)
    else
        print("Nie wpisano nicku lub nie znaleziono gracza! Przycisk zablokowany.")
    end
end)

offBtn.MouseButton1Click:Connect(function()
    if targetPlayer and targetPlayer.Character then
        -- Najprostsza metoda na przywrócenie oryginalnych animacji serwerowo bez kombinowania: ubicie postaci
        targetPlayer.Character:BreakJoints() 
        targetPlayer = nil
    end
end)

