-- LOGIKA
local targetPlayer = nil
local activeAnims = {}

local function getTrueId(id) return "rbxassetid://" .. tostring(id) end

local function applyAnimations(char)
    local hum = char:WaitForChild("Humanoid")
    local animate = char:FindFirstChild("Animate")
    
    -- Kluczowy moment: Usuwamy oryginalne skrypty ruchu gracza
    if animate then animate:Destroy() end
    
    local anims = {
        Run = getTrueId("108985707207747"),
        Walk = getTrueId("84792004932424"),
        Idle1 = getTrueId("120467296669059"),
        Idle2 = getTrueId("73644021399239")
    }

    local animator = hum:FindFirstChild("Animator") or Instance.new("Animator", hum)
    
    for name, id in pairs(anims) do
        local anim = Instance.new("Animation")
        anim.AnimationId = id
        local track = animator:LoadAnimation(anim)
        track:Play()
        activeAnims[name] = track
    end
end

local function findTarget(name)
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name:lower() then return p end
    end
    return nil
end

onBtn.MouseButton1Click:Connect(function()
    local p = findTarget(nameInput.Text)
    if p and p.Character then
        targetPlayer = p
        applyAnimations(p.Character)
        print("Przejęto kontrolę nad: " .. p.Name)
    end
end)

offBtn.MouseButton1Click:Connect(function()
    if targetPlayer and targetPlayer.Character then
        -- Tutaj przywracamy domyślne animacje (np. poprzez reset postaci)
        targetPlayer.Character:BreakJoints() 
        targetPlayer = nil
        for _, track in pairs(activeAnims) do track:Stop() end
    end
end)

